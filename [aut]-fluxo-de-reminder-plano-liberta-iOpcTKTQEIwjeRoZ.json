onditions":[{"id":"9e56b846-3336-4cca-8890-bf7f92fe554f","leftValue":"={{ $json.body.event }}","rightValue":"PURCHASE_CANCELED","operator":{"type":"string","operation":"equals","name":"filter.operator.equals"}}],"combinator":"and"}},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"8f6655c1-09fb-4ac9-8d49-527e76e839a7","leftValue":"={{ $json.body.event }}","rightValue":"PURCHASE_REFUNDED","operator":{"type":"string","operation":"equals","name":"filter.operator.equals"}}],"combinator":"and"}},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"75116041-77c0-4a61-83a6-74d3a9802031","leftValue":"={{ $json.body.event }}","rightValue":"PURCHASE_APPROVED","operator":{"type":"string","operation":"equals","name":"filter.operator.equals"}}],"combinator":"and"}}]},"options":{}},"type":"n8n-nodes-base.switch","typeVersion":3.2,"position":[-6224,-432],"id":"ed460fe8-8b45-4845-9b5a-951b7fff1fbb","name":"Verifica evento da Kiwify"},{"parameters":{"jsCode":"// === CONFIG ===\n// Troque \"Webhook\" pelo nome EXATO do seu nó Webhook, se for diferente.\nconst WEBHOOK_NODE = \"Webhook\";\n\n// === HELPERS ===\nfunction get(obj, path) {\n  return path.split('.').reduce((o, k) => (o && o[k] !== undefined ? o[k] : undefined), obj);\n}\nfunction urlDecodeSafe(s){ try { return decodeURIComponent(s); } catch { return s; } }\nfunction tryParseBase64Json(s){\n  try{\n    const b64 = s.replace(/-/g, '+').replace(/_/g, '/');\n    const json = Buffer.from(b64, 'base64').toString('utf8');\n    const obj = JSON.parse(json);\n    return {\n      utm_source: obj.us ?? obj.utm_source ?? '',\n      utm_medium: obj.um ?? obj.utm_medium ?? '',\n      utm_campaign: obj.uc ?? obj.utm_campaign ?? '',\n      utm_content: obj.uct ?? obj.utm_content ?? '',\n      utm_term: obj.ut ?? obj.utm_term ?? '',\n    };\n  } catch { return null; }\n}\nfunction splitPlain(s){\n  const sep = s.includes('|') ? '|' : (s.includes('~') ? '~' : '|');\n  const parts = s.split(sep).map(v => urlDecodeSafe(v.replace(/\\+/g, ' ').trim()));\n  while (parts.length < 5) parts.push('');\n  const [utm_source, utm_medium, utm_campaign, utm_content, utm_term] = parts;\n  return { utm_source, utm_medium, utm_campaign, utm_content, utm_term };\n}\nfunction parseXcod(s){\n  if (!s) return { utm_source:'', utm_medium:'', utm_campaign:'', utm_content:'', utm_term:'' };\n  const asJson = tryParseBase64Json(s);\n  return asJson ?? splitPlain(s);\n}\n\n// === CAPTURA O xcod DIRETO DO NÓ WEBHOOK ===\n// Pega os itens do nó \"Webhook\" (saída 0)\nconst webhookItems = $items(WEBHOOK_NODE, 0) || [];\nconst w = webhookItems[0]?.json || {};\n\n// O payload pode vir \"embrulhado\" em body.data... (URL de teste) ou direto em data...\nconst candidates = [\n  get(w, 'body.data.purchase.origin.xcod'),\n  get(w, 'data.purchase.origin.xcod'),\n  get(w, 'purchase.origin.xcod'),\n  get(w, 'origin.xcod'),\n];\n\nconst xcod = (candidates.find(v => typeof v === 'string' && v.length) || '').toString();\n\n// Faz o parse das UTMs\nconst utm = parseXcod(xcod);\n\n// === OUTPUT APENAS AS MÉTRICAS ===\nreturn [{\n  json: {\n    utm_source: utm.utm_source,\n    utm_medium: utm.utm_medium,\n    utm_campaign: utm.utm_campaign,\n    utm_content: utm.utm_content,\n    utm_term: utm.utm_term,\n  }\n}];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-5488,-512],"id":"3f067d07-d339-4c4c-90c1-6ab64361ce35","name":"Filtra as utms"},{"parameters":{"resource":"tag","operation":"getAll","returnAll":true},"type":"n8n-nodes-base.activeCampaign","typeVersion":1,"position":[-5472,-1040],"id":"5c06474a-67a6-474f-9523-bbeeaa16bd6c","name":"Verifica ID das tags","credentials":{"activeCampaignApi":{"id":"5offhZaqy5czb4wd","name":"https://meuconsultoriointeligente.api-us1.com"}}},{"parameters":{"url":"https://meuconsultoriointeligente.api-us1.com/api/3/fields","sendHeaders":true,"specifyHeaders":"