tDate(newDate.getDate() + days);\n    return `${newDate.getDate().toString().padStart(2, '0')}/${(newDate.getMonth() + 1).toString().padStart(2, '0')}/${newDate.getFullYear()}`;\n}\n\n// Converte a data inicial (segunda-feira)\nconst monday = parseDate(inputDate);\n\n// Calcula os dias seguintes\nconst tuesday = addDays(monday, 2);\nconst wednesday = addDays(monday, 3);\nconst thursday = addDays(monday, 4);\nconst friday = addDays(monday, 5);\n\n// Retorna a saída formatada corretamente\nreturn [\n  {\n    \"segunda-feira\": `${inputDate}`,\n    \"terça-feira\": `${tuesday}`,\n    \"quarta-feira\": `${wednesday}`,\n    \"quinta-feira\": `${thursday}`,\n    \"sexta-feira\": `${friday}`\n  }\n];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-2304,-1104],"id":"88de71c4-9055-4314-9fda-6fa6b59b7754","name":"Calcula datas de RMD"},{"parameters":{"jsCode":"const inputDate = $input.first().json['DATA RMD']; // Exemplo: \"05/04/2026\" (domingo)\n\n// Função para converter string \"DD/MM/YYYY\" para um objeto Date\nfunction parseDate(dateStr) {\n    const [day, month, year] = dateStr.split(\"/\").map(Number);\n    return new Date(year, month - 1, day); // JavaScript usa mês indexado em 0\n}\n\n// Função para adicionar ou subtrair dias e formatar como \"DD/MM/YYYY\"\nfunction addDays(date, days) {\n    const newDate = new Date(date);\n    newDate.setDate(newDate.getDate() + days);\n    return ${newDate.getDate().toString().padStart(2, '0')}/${(newDate.getMonth() + 1).toString().padStart(2, '0')}/${newDate.getFullYear()};\n}\n\n// Converte a data inicial (domingo)\nconst sunday = parseDate(inputDate);\n\n// Calcula os dias anteriores\nconst monday = addDays(sunday, -6);\nconst tuesday = addDays(sunday, -5);\nconst wednesday = addDays(sunday, -4);\nconst thursday = addDays(sunday, -3);\nconst friday = addDays(sunday, -2);\nconst saturday = addDays(sunday, -1);\n\n// Retorna a saída formatada corretamente\nreturn [\n  {\n    json: {\n      \"segunda-feira\": monday,\n      \"terça-feira\": tuesday,\n      \"quarta-feira\": wednesday,\n      \"quinta-feira\": thursday,\n      \"sexta-feira\": friday,\n      \"sábado\": saturday,\n      \"domingo\": inputDate\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-2992,32],"id":"933e550c-754b-478c-ab5b-4e3452dabe9c","name":"Calcula datas de RMD1"},{"parameters":{"jsCode":"const opcoes = ['2', '5', '7', '10'];\nconst indice = Math.floor(Math.random() * opcoes.length);\nconst opcaoSelecionada = opcoes[indice];\n\nreturn [\n  {\n    json: {\n      opcao: opcaoSelecionada\n    }\n  }\n];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-4288,-656],"id":"7c6b8b96-8041-418e-9776-b82511337ec7","name":"Randomiza o tempo de espera2"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"leftValue":"={{ $json.opcao }}","rightValue":"2","operator":{"type":"string","operation":"equals"},"id":"cf5140a2-4302-409b-bf9f-cc06047486bc"}],"combinator":"and"},"renameOutput":true,"outputKey":"2"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"74b977fe-5839-4a62-97ff-a955b9ec2799","leftValue":"={{ $json.opcao }}","rightValue":"5","operator":{"type":"string","operation":"equals","name":"filter.operator.equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"5"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"c56ff9ab-0ce4-4250-9ff5-587adbafe3dd","leftValue":"={{ $json.opcao }}","rightValue":"7","operator":{"type":"string","operation":"equals","name":"filter.operator.equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"7"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"a522d375-fac4-4863-954b-6f62f08354fd","leftValue":"={{ $json.opcao }